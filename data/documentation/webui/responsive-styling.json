{"abstract":[{"text":"Design responsive layouts and components that adapt to different screen sizes with WebUI’s powerful responsive styling features.","type":"text"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/WebUI\/documentation\/WebUI"]]},"metadata":{"title":"Responsive Styling","role":"article","roleHeading":"Article","modules":[{"name":"WebUI"}]},"variants":[{"paths":["\/documentation\/webui\/responsive-styling"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/WebUI\/documentation\/WebUI\/Element","doc:\/\/WebUI\/documentation\/WebUI\/Modifier"],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/WebUI\/documentation\/WebUI\/getting-started"],"anchor":"Essentials","generated":true,"title":"Essentials"}],"identifier":{"url":"doc:\/\/WebUI\/documentation\/WebUI\/responsive-styling","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"WebUI offers two approaches to responsive styling, each with its own strengths and use cases:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modifier-based approach"}]},{"type":"text","text":": Apply styles conditionally using the "},{"code":"on","type":"codeVoice"},{"text":" parameter with breakpoint modifiers like ","type":"text"},{"code":".md","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":".lg"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Block-based approach"}]},{"type":"text","text":": Define responsive styles for multiple breakpoints in a single, declarative block"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Breakpoint-Modifiers","type":"heading","text":"Breakpoint Modifiers","level":2},{"type":"paragraph","inlineContent":[{"text":"WebUI includes standard breakpoint modifiers that follow Tailwind CSS conventions:","type":"text"}]},{"rows":[[[{"inlineContent":[{"type":"text","text":"Modifier"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Screen Width","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":".xs","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"480px+"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Extra small devices (larger phones)","type":"text"}]}]],[[{"inlineContent":[{"code":".sm","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"640px+"}]}],[{"inlineContent":[{"text":"Small devices (tablets, large phones)","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".md"}]}],[{"inlineContent":[{"text":"768px+","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium devices (tablets)","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".lg"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1024px+"}]}],[{"inlineContent":[{"text":"Large devices (desktops)","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".xl"}]}],[{"inlineContent":[{"type":"text","text":"1280px+"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Extra large devices (large desktops)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".xl2","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1536px+"}]}],[{"inlineContent":[{"type":"text","text":"2x Extra large devices (very large desktops)"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Modifier-Based-Approach","type":"heading","level":2,"text":"Modifier-Based Approach"},{"inlineContent":[{"type":"text","text":"The traditional approach applies responsive styles by using the "},{"code":"on","type":"codeVoice"},{"text":" parameter with breakpoint modifiers:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Text { \"Responsive Text\" }","  .font(size: .sm)","  .font(size: .base, on: .md)","  .font(size: .lg, on: .lg)","  .margins(of: 2)","  .margins(of: 4, on: .md)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This approach works well for:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Simple responsive adjustments"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Single-property changes across breakpoints","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maintaining backward compatibility"}]}]}]},{"level":2,"text":"Block-Based Approach","type":"heading","anchor":"Block-Based-Approach"},{"type":"paragraph","inlineContent":[{"text":"The new block-based approach allows defining responsive styles for multiple breakpoints and properties in a single, declarative block:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Text { \"Responsive Text\" }","  .font(size: .sm)","  .responsive {","    $0.md {","      $0.font(size: .base)","      $0.margins(of: 4)","    }","    $0.lg {","      $0.font(size: .lg)","      $0.margins(of: 6)","    }","  }"]},{"type":"paragraph","inlineContent":[{"text":"This approach is ideal for:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Complex responsive layouts with multiple property changes","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Improved code organization and readability"}]}]},{"content":[{"inlineContent":[{"text":"Clearer representation of breakpoint-specific styling","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Complex-Examples","type":"heading","text":"Complex Examples"},{"text":"Responsive Card Component","type":"heading","anchor":"Responsive-Card-Component","level":3},{"code":["Stack(classes: [\"card\"])","  \/\/ Using EdgeInsets for different padding on each side","  .padding(EdgeInsets(top: 4, leading: 6, bottom: 4, trailing: 6))","  .background(color: .white)","  .shadow(of: .sm)","  .rounded(.md)","  .responsive {","    $0.md {","      \/\/ Uniform padding using EdgeInsets","      $0.padding(EdgeInsets(all: 6))","      $0.shadow(of: .md)","    }","    $0.lg {","      \/\/ Different vertical\/horizontal padding with EdgeInsets","      $0.padding(EdgeInsets(vertical: 8, horizontal: 12))","      $0.flex(direction: .row)","    }","  }"],"syntax":"swift","type":"codeListing"},{"text":"Responsive Navigation","level":3,"anchor":"Responsive-Navigation","type":"heading"},{"syntax":"swift","code":["Navigation {","  \/\/ Mobile navigation (hamburger menu)","  Stack(classes: [\"hamburger-menu\"])","    .responsive {","      $0.lg {","        $0.hidden()  \/\/ Hide on large screens","      }","    }","    ","  \/\/ Desktop navigation links","  Stack(classes: [\"desktop-menu\"])","    .hidden()  \/\/ Hidden by default on mobile","    .responsive {","      $0.lg {","        $0.hidden(false)  \/\/ Show on large screens","        $0.flex(direction: .row, justify: .between)","      }","    }","}"],"type":"codeListing"},{"anchor":"Responsive-Typography-System","type":"heading","text":"Responsive Typography System","level":3},{"code":["\/\/ Page title","Heading(.largeTitle) { \"Welcome to WebUI\" }","  .font(size: .xl3, weight: .bold)","  .responsive {","    $0.md {","      $0.font(size: .xl4)","    }","    $0.lg {","      $0.font(size: .xl5)","    }","  }","","\/\/ Section heading","Heading(.title) { \"Key Features\" }","  .font(size: .xl, weight: .semibold)","  \/\/ Add margins with EdgeInsets","  .margins(EdgeInsets(top: 4, leading: 0, bottom: 2, trailing: 0))","  .responsive {","    $0.md {","      $0.font(size: .xl2)","      \/\/ Different margins at medium breakpoint","      $0.margins(EdgeInsets(top: 6, leading: 0, bottom: 3, trailing: 0))","    }","  }"],"type":"codeListing","syntax":"swift"},{"text":"Combining Approaches","level":2,"anchor":"Combining-Approaches","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You can combine both approaches when needed, though the block-based approach is generally recommended for clarity:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Button { \"Sign Up\" }","  .background(color: .blue(._500))","  \/\/ Using EdgeInsets for different padding values","  .padding(EdgeInsets(vertical: 2, horizontal: 4))","  .font(color: .white, weight: .semibold)","  \/\/ One-off responsive adjustment","  .rounded(.full, on: .lg)","  \/\/ Block of related responsive adjustments","  .responsive {","    $0.md {","      \/\/ Combining EdgeInsets with responsive design","      $0.padding(EdgeInsets(vertical: 3, horizontal: 6))","    }","    $0.lg {","      $0.background(color: .blue(._600))","      \/\/ Advanced EdgeInsets with different values for each edge","      $0.padding(EdgeInsets(top: 3, leading: 8, bottom: 3, trailing: 8))","    }","  }"]},{"text":"Using EdgeInsets for Precise Spacing","level":2,"anchor":"Using-EdgeInsets-for-Precise-Spacing","type":"heading"},{"inlineContent":[{"text":"EdgeInsets allows you to define different spacing values for each edge (top, leading, bottom, trailing) in a single method call:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Different values for each edge","Element(tag: \"div\")","  .padding(EdgeInsets(top: 4, leading: 6, bottom: 8, trailing: 6))","","\/\/ Same value for all edges","Button() { \"Submit\" }","  .margins(EdgeInsets(all: 4))","","\/\/ Different vertical and horizontal values","Stack()","  .padding(EdgeInsets(vertical: 2, horizontal: 4))"],"type":"codeListing"},{"inlineContent":[{"text":"EdgeInsets can be used with:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"padding()","type":"codeVoice"},{"text":": Apply padding to elements","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"margins()"},{"type":"text","text":": Set margins around elements"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"border()"},{"text":": Define border widths for each edge","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"position()"},{"text":": Set position offsets for each edge","type":"text"}]}]}]},{"text":"Best Practices","type":"heading","level":2,"anchor":"Best-Practices"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Group Related Styles","type":"text"}],"type":"strong"},{"text":": Use the block-based approach to group styles that change together at specific breakpoints","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Consider Mobile-First"}],"type":"strong"},{"type":"text","text":": Start with the default mobile styles and progressively enhance for larger screens"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use Meaningful Breakpoints","type":"text"}],"type":"strong"},{"type":"text","text":": Choose breakpoints based on content needs rather than specific devices"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Avoid Breakpoint Proliferation"}],"type":"strong"},{"text":": Limit the number of different breakpoints to maintain consistency","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Use EdgeInsets for Precision"}]},{"type":"text","text":": When elements need different spacing values on each side, use EdgeInsets instead of multiple edge-specific calls"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Test Across Devices"}],"type":"strong"},{"text":": Always test responsive designs on actual devices or using browser dev tools","type":"text"}]}]}]}]}],"references":{"doc://WebUI/documentation/WebUI/getting-started":{"url":"\/documentation\/webui\/getting-started","type":"topic","kind":"article","abstract":[{"type":"text","text":"Create static and dynamic websites using Swift with WebUI’s component-based, type-safe API."}],"title":"Getting Started with WebUI","role":"article","identifier":"doc:\/\/WebUI\/documentation\/WebUI\/getting-started"},"doc://WebUI/documentation/WebUI/Element":{"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Element"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Element","kind":"identifier"}],"abstract":[{"type":"text","text":"Base class for creating HTML elements."}],"title":"Element","type":"topic","url":"\/documentation\/webui\/element","identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Element"},"doc://WebUI/documentation/WebUI/Modifier":{"type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Modifier","kind":"identifier"}],"navigatorTitle":[{"text":"Modifier","kind":"identifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/webui\/modifier","abstract":[{"type":"text","text":"Represents CSS modifiers that apply styles under specific conditions, such as hover or focus states."}],"identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Modifier","title":"Modifier"},"doc://WebUI/documentation/WebUI":{"title":"WebUI","type":"topic","abstract":[{"text":"Create beautiful static and dynamic websites using Swift.","type":"text"}],"identifier":"doc:\/\/WebUI\/documentation\/WebUI","role":"collection","kind":"symbol","url":"\/documentation\/webui"}}}