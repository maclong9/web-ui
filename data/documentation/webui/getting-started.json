{"sections":[],"hierarchy":{"paths":[["doc:\/\/WebUI\/documentation\/WebUI"]]},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"WebUI is a Swift library for building websites using a declarative, component-based approach. It offers a type-safe way to create HTML, with built-in styling inspired by SwiftUI, and all in pure Swift. WebUI can be used for both static site generation and dynamic server-rendered content.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This article covers the basics of getting started with WebUI, from installation to creating your first page."}],"type":"paragraph"},{"anchor":"Adding-WebUI-to-Your-Project","text":"Adding WebUI to Your Project","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add WebUI to your Swift package by adding it as a dependency in your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" file:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ swift-tools-version: 6.1","import PackageDescription","","let package = Package(","    name: \"MyWebsite\",","    platforms: [.macOS(.v15)],","    dependencies: [","        .package(url: \"https:\/\/github.com\/maclong9\/web-ui.git\", from: \"1.0.0\"),","    ],","    targets: [","        .executableTarget(","            name: \"MyWebsite\",","            dependencies: [","                .product(name: \"WebUI\", package: \"web-ui\")","            ],","            path: \"Sources\",","            resources: [.process(\"Public\")] \/\/ Add your asset files here","        )","    ]",")"]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"You can also create a site as part of a monorepo project by removing the ","type":"text"},{"type":"codeVoice","code":"path"},{"type":"text","text":" from the target and creating the directory structure for your site as "},{"type":"codeVoice","code":"Sources\/TargetName\/*"},{"type":"text","text":"."}]}]},{"text":"Creating Your First Page","type":"heading","level":2,"anchor":"Creating-Your-First-Page"},{"type":"paragraph","inlineContent":[{"text":"To create a basic web page with WebUI, you need three key components:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Metadata","type":"text"}]},{"text":": Information about the page like title and description","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Content"}]},{"type":"text","text":": The actual HTML elements and text for the page"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Document"}]},{"text":": The container that brings metadata and content together","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Here’s a simple example:"}],"type":"paragraph"},{"syntax":"swift","code":["import WebUI","","let homePage = Document(","    path: \"index\",","    metadata: Metadata(","        title: \"My First Page\",","        description: \"A simple page built with WebUI\"","    ),","    content: {","        Header {","            Heading(.largeTitle) { \"Welcome to My Website\" }","        }","","        Main {","            Text { \"This is my first page built with WebUI. It's so easy!\" }","","            Link(to: \"https:\/\/github.com\") { \"Visit GitHub\" }","        }","","        Footer {","            Text { \"© 2025 My Website\" }","        }","    }",")"],"type":"codeListing"},{"type":"heading","text":"Building a Complete Website","level":2,"anchor":"Building-a-Complete-Website"},{"inlineContent":[{"text":"To create a complete website with multiple pages, you’ll use the ","type":"text"},{"identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Website","isActive":true,"type":"reference"},{"type":"text","text":" struct, the "},{"identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Metadata","type":"reference","isActive":true},{"type":"text","text":" here is applied to all pages:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import WebUI","","let website = Website(","    metadata: Metadata(","        site: \"My Website\",","        description: \"A website built with WebUI\"","    ),","    routes: [","        homePage,","        aboutPage,","        contactPage","    ]",")","","\/\/ Build the static site","try website.build(to: URL(filePath: \".output\")) \/\/ `.output` is the default value"]},{"level":2,"type":"heading","anchor":"Styling-Elements","text":"Styling Elements"},{"type":"paragraph","inlineContent":[{"text":"WebUI provides a SwiftUI like modifier API for styling your elements:","type":"text"}]},{"type":"codeListing","code":["Button(type: .submit) { \"Submit\" }","    .background(color: .blue(.500))","    .font(color: .white)","    .padding(of: 4, at: .all)","    .rounded(.md)","    .font(weight: .semibold)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can also use EdgeInsets for precise control over spacing on different sides:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Button(type: .submit) { \"Submit\" }","    .background(color: .blue(.500))","    .font(color: .white)","    \/\/ Apply different padding to each side","    .padding(EdgeInsets(top: 2, leading: 6, bottom: 2, trailing: 6))","    .rounded(.md)","    .font(weight: .semibold)","","\/\/ Different margins for vertical and horizontal sides","Stack(classes: [\"card\"])","    .margins(EdgeInsets(vertical: 4, horizontal: 6))","","\/\/ Same border width on all sides","Image(src: \"profile.jpg\", alt: \"Profile photo\")","    .border(EdgeInsets(all: 2), style: .solid, color: .gray(._300))"]},{"type":"heading","text":"Next Steps","anchor":"Next-Steps","level":2},{"type":"paragraph","inlineContent":[{"text":"Now that you understand the basics of WebUI:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Try the "},{"identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site","type":"reference","isActive":true},{"type":"text","text":" tutorial for a full look at the recommended way to structure your website, pages and components."}]}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/webui\/getting-started"]}],"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"WebUI"}],"title":"Getting Started with WebUI"},"identifier":{"url":"doc:\/\/WebUI\/documentation\/WebUI\/getting-started","interfaceLanguage":"swift"},"abstract":[{"text":"Create static and dynamic websites using Swift with WebUI’s component-based, type-safe API.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/WebUI\/documentation\/WebUI\/responsive-styling"],"anchor":"Essentials"}],"kind":"article","references":{"doc://WebUI/tutorials/WebUI/creating-a-static-site":{"type":"topic","abstract":[{"text":"Learn how to build a simple static website with a home page and an about page using the WebUI library.","type":"text"}],"estimatedTime":"30min","kind":"project","title":"Creating a Static Site","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site","url":"\/tutorials\/webui\/creating-a-static-site","role":"project"},"doc://WebUI/documentation/WebUI/responsive-styling":{"role":"article","url":"\/documentation\/webui\/responsive-styling","identifier":"doc:\/\/WebUI\/documentation\/WebUI\/responsive-styling","abstract":[{"text":"Design responsive layouts and components that adapt to different screen sizes with WebUI’s powerful responsive styling features.","type":"text"}],"title":"Responsive Styling","type":"topic","kind":"article"},"doc://WebUI/documentation/WebUI/Metadata":{"abstract":[{"text":"Represents metadata for an HTML document including SEO and social media properties.","type":"text"}],"type":"topic","title":"Metadata","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Metadata","kind":"identifier"}],"url":"\/documentation\/webui\/metadata","navigatorTitle":[{"kind":"identifier","text":"Metadata"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Metadata"},"doc://WebUI/documentation/WebUI":{"title":"WebUI","type":"topic","abstract":[{"text":"Create beautiful static and dynamic websites using Swift.","type":"text"}],"identifier":"doc:\/\/WebUI\/documentation\/WebUI","role":"collection","kind":"symbol","url":"\/documentation\/webui"},"doc://WebUI/documentation/WebUI/Website":{"abstract":[{"text":"Manages and builds a collection of routes (documents) into a complete static website.","type":"text"}],"navigatorTitle":[{"text":"Website","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Website"}],"kind":"symbol","url":"\/documentation\/webui\/website","role":"symbol","identifier":"doc:\/\/WebUI\/documentation\/WebUI\/Website","type":"topic","title":"Website"}}}