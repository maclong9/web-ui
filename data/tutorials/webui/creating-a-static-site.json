{"hierarchy":{"modules":[{"reference":"doc:\/\/WebUI\/tutorials\/table-of-contents\/Building-Static-Sites","projects":[{"reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site","sections":[{"kind":"task","reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Set-Up-Your-Project"},{"reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-a-Layout-Component","kind":"task"},{"reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-the-Home-Page","kind":"task"},{"kind":"task","reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-the-About-Page"},{"kind":"task","reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Build-the-Website"},{"reference":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Check-Your-Understanding","kind":"assessment"}]}]}],"paths":[["doc:\/\/WebUI\/tutorials\/table-of-contents","doc:\/\/WebUI\/tutorials\/table-of-contents\/$volume","doc:\/\/WebUI\/tutorials\/table-of-contents\/Building-Static-Sites"],["doc:\/\/WebUI\/documentation\/WebUI"]],"reference":"doc:\/\/WebUI\/tutorials\/table-of-contents"},"sections":[{"chapter":"Building Static Sites","kind":"hero","title":"Creating a Static Site","content":[{"inlineContent":[{"text":"Learn how to build a simple static website with a home page and an about page using the WebUI library.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This tutorial will walk you through setting up a WebUI project, creating a reusable layout component, building pages with different content, adding navigation between them, and generating the final static site.","type":"text"}]}],"estimatedTimeInMinutes":30},{"kind":"tasks","tasks":[{"anchor":"Set-Up-Your-Project","stepsSection":[{"code":"terminal-init.sh","content":[{"type":"paragraph","inlineContent":[{"text":"First, create a new directory for your project and initialize a Swift package.","type":"text"}]}],"runtimePreview":null,"type":"step","caption":[],"media":null},{"code":"package-swift.swift","type":"step","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Update your Package.swift file to add the WebUI dependency."}],"type":"paragraph"}],"caption":[],"media":null},{"code":"terminal-sources.sh","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a Sources directory structure for your project."}]}],"runtimePreview":null,"type":"step","caption":[{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"This structure is an example of how you can organize your project files.","type":"text"}],"type":"paragraph"}]}],"media":null},{"caption":[],"code":"terminal-structure.txt","media":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"The directory structure will look like this:","type":"text"}],"type":"paragraph"}],"type":"step"}],"contentSection":[{"kind":"fullWidth","content":[{"inlineContent":[{"text":"Create a new Swift project and add the WebUI dependency.","type":"text"}],"type":"paragraph"}]}],"title":"Set Up Your Project"},{"title":"Create a Layout Component","contentSection":[{"content":[{"inlineContent":[{"text":"Build a reusable layout component that will provide consistent structure across all pages.","type":"text"}],"type":"paragraph"}],"kind":"fullWidth"}],"stepsSection":[{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"This component will be reused across all pages to maintain a consistent look and feel.","type":"text"}]}],"content":[{"inlineContent":[{"type":"text","text":"Let’s create a Layout component, in "},{"code":"Sources\/Components\/Layout.swift","type":"codeVoice"},{"text":" that will serve as the foundation for our website. Our Layout will create a struct conforming to the ","type":"text"},{"code":"HTML","type":"codeVoice"},{"type":"text","text":" protocol and accept children via an HTMLBuilder closure. It will provide a consistent header with navigation links, a main content area for page-specific content, and a footer with copyright information."}],"type":"paragraph"}],"media":null,"runtimePreview":null,"code":"layout-component.swift"}],"anchor":"Create-a-Layout-Component"},{"stepsSection":[{"type":"step","media":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new Swift file called Home.swift in your Sources directory."}]}],"code":"home-page.swift","caption":[{"inlineContent":[{"text":"In this file, we’ll create a ","type":"text"},{"code":"Home","type":"codeVoice"},{"type":"text","text":" struct that conforms to the "},{"code":"HTML","type":"codeVoice"},{"type":"text","text":" protocol with a "},{"type":"codeVoice","code":"document"},{"type":"text","text":" property that creates a Document with metadata and content. We’ll implement a "},{"type":"codeVoice","code":"render()"},{"text":" method that uses our Layout component to wrap the page-specific content, defining a Section with a heading and paragraphs. The Layout component handles the header, navigation, and footer automatically, so we only need to focus on the main content.","type":"text"}],"type":"paragraph"}]}],"contentSection":[{"kind":"fullWidth","content":[{"inlineContent":[{"type":"text","text":"Build the main landing page for your static site with a welcoming message and navigation."}],"type":"paragraph"}]}],"anchor":"Create-the-Home-Page","title":"Create the Home Page"},{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Add a second page with information about your site or project."}],"type":"paragraph"}],"kind":"fullWidth"}],"title":"Create the About Page","stepsSection":[{"media":null,"code":"about-page.swift","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Create a new Swift file called About.swift in your Sources directory.","type":"text"}]}],"caption":[{"inlineContent":[{"text":"The About page also uses the same Layout component but customizes it with different page metadata (title and description). It contains unique content about your site including multiple sections, feature descriptions, and a styled link button to return to the home page. By using the Layout component, we ensure consistency across pages.","type":"text"}],"type":"paragraph"}]}],"anchor":"Create-the-About-Page"},{"anchor":"Build-the-Website","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Create the main file that defines your website and builds the static HTML files.","type":"text"}]}],"kind":"fullWidth"}],"stepsSection":[{"caption":[{"inlineContent":[{"type":"text","text":"This main file imports the WebUI library and creates shared metadata for all pages. It defines a theme with fonts and colors, sets up the Application configuration, and configures the website with both pages as routes. Finally, it builds the static HTML files to the specified output directory."}],"type":"paragraph"}],"type":"step","media":null,"code":"application-main.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Create an Application.swift file to define your website and build it.","type":"text"}]}],"runtimePreview":null},{"type":"step","code":"terminal-build.sh","runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When the build completes, check your output directory to find the generated HTML files. You’ll see index.html (Home page), about\/index.html (About page), and a public directory with any assets. You can now open these files in a browser or deploy them to a web server."}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Build and run your project to generate the static site.","type":"text"}]}],"media":null},{"runtimePreview":null,"media":"final-output.png","code":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"After building the site, you can preview it locally by opening the index.html file in a web browser. Alternatively, you can use a simple HTTP server to serve the files from the output directory.","type":"text"}]}],"type":"step","content":[{"inlineContent":[{"text":"Preview the generated site locally.","type":"text"}],"type":"paragraph"}]}],"title":"Build the Website"}]},{"assessments":[{"content":[],"title":[{"inlineContent":[{"text":"What benefit does the Layout component provide when building a multi-page site?","type":"text"}],"type":"paragraph"}],"choices":[{"justification":[{"inlineContent":[{"type":"text","text":"The Layout component doesn’t handle page transitions or animations. It provides a consistent structure across multiple pages."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"It automatically adds animations to page transitions"}],"type":"paragraph"}],"isCorrect":false},{"isCorrect":true,"justification":[{"inlineContent":[{"text":"Correct! The Layout component encapsulates common elements like the header, navigation, and footer, ensuring they’re consistent across all pages while allowing for different content. It also maintains consistent spacing using EdgeInsets across all pages.","type":"text"}],"type":"paragraph"}],"content":[{"type":"paragraph","inlineContent":[{"text":"It ensures header, navigation, and footer are consistent across all pages","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It reduces the file size of the generated HTML"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"While the Layout component helps with code organization and reuse, it doesn’t directly impact the size of the generated HTML files. Its primary purpose is to maintain consistent structure and styling.","type":"text"}],"type":"paragraph"}]}],"type":"multiple-choice"},{"title":[{"inlineContent":[{"text":"How do you create a collection of pages to build as a website?","type":"text"}],"type":"paragraph"}],"content":[],"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"Website","type":"codeVoice"},{"type":"text","text":" struct with an array of "},{"code":"Document","type":"codeVoice"},{"text":" instances","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"Correct! The ","type":"text"},{"type":"codeVoice","code":"Website"},{"text":" struct takes an array of ","type":"text"},{"code":"Document","type":"codeVoice"},{"type":"text","text":" instances in its "},{"code":"routes","type":"codeVoice"},{"type":"text","text":" parameter to define all the pages of your site. In our implementation, we configure the Application with these routes, which are then used by both the Website constructor and the Layout component."}]}]},{"justification":[{"type":"paragraph","inlineContent":[{"text":"Individual ","type":"text"},{"code":"Document","type":"codeVoice"},{"type":"text","text":" instances don’t have a "},{"type":"codeVoice","code":"build()"},{"type":"text","text":" method. You need to use the "},{"type":"codeVoice","code":"Website"},{"type":"text","text":" struct to collect and build multiple pages."}]}],"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"build()","type":"codeVoice"},{"text":" method on each ","type":"text"},{"type":"codeVoice","code":"Document"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a "},{"code":"StaticSite","type":"codeVoice"},{"type":"text","text":" with page URLs"}]}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"WebUI doesn’t have a "},{"type":"codeVoice","code":"StaticSite"},{"text":" type. You should use the ","type":"text"},{"code":"Website","type":"codeVoice"},{"type":"text","text":" struct to define your static site."}],"type":"paragraph"}]}]}],"kind":"assessments","anchor":"Check-Your-Understanding"}],"metadata":{"role":"project","categoryPathComponent":"table-of-contents","title":"Creating a Static Site","category":"WebUI"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/webui\/creating-a-static-site"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site","interfaceLanguage":"swift"},"kind":"project","references":{"package-swift.swift":{"highlights":[],"identifier":"package-swift.swift","content":["\/\/ swift-tools-version: 6.1","","import PackageDescription","","let package = Package(","    name: \"example\",","    platforms: [.macOS(.v15)],","    dependencies: [","        .package(url: \"https:\/\/github.com\/maclong9\/web-ui.git\", from: \"1.0.0\")","    ],","    targets: [","        .executableTarget(","            name: \"Application\",","            dependencies: [","                .product(name: \"WebUI\", package: \"web-ui\")","            ],","            path: \"Sources\",","            resources: [.process(\"Public\")]","        )","    ]",")"],"syntax":"swift","fileType":"swift","fileName":"Package.swift","type":"file"},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Set-Up-Your-Project":{"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/webui\/creating-a-static-site#Set-Up-Your-Project","title":"Set Up Your Project","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Set-Up-Your-Project","abstract":[{"text":"Learn how to build a simple static website with a home page and an about page using the WebUI library.","type":"text"}]},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Check-Your-Understanding":{"identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link","url":"\/tutorials\/webui\/creating-a-static-site#Check-Your-Understanding","title":"Check Your Understanding"},"doc://WebUI/tutorials/WebUI/creating-a-static-site":{"type":"topic","abstract":[{"text":"Learn how to build a simple static website with a home page and an about page using the WebUI library.","type":"text"}],"estimatedTime":"30min","kind":"project","title":"Creating a Static Site","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site","url":"\/tutorials\/webui\/creating-a-static-site","role":"project"},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Create-the-Home-Page":{"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/webui\/creating-a-static-site#Create-the-Home-Page","title":"Create the Home Page","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-the-Home-Page","abstract":[{"type":"text","text":"Learn how to build a simple static website with a home page and an about page using the WebUI library."}]},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Create-a-Layout-Component":{"url":"\/tutorials\/webui\/creating-a-static-site#Create-a-Layout-Component","abstract":[{"type":"text","text":"Learn how to build a simple static website with a home page and an about page using the WebUI library."}],"role":"pseudoSymbol","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-a-Layout-Component","kind":"section","title":"Create a Layout Component","type":"section"},"home-page.swift":{"type":"file","syntax":"swift","highlights":[],"content":["import WebUI","","struct Home: HTML {","    var document: Document {","        .init(","            path: \"\/\",","            metadata: Metadata(","                title: \"Home\",","                description: \"Welcome to my personal website built with WebUI\"","            ),","            content: { self }","        )","    }","","    func render() -> String {","        Layout {","            Section {","                Heading(.title) {","                    \"Welcome to My Website\"","                }","                .font(size: .xl3, weight: .bold)","                .margins(at: .bottom)","","                Text {","                    \"This is a simple static website built with WebUI and Swift. WebUI makes it easy to create clean, semantic HTML without writing any HTML directly.\"","                }","                .margins(at: .bottom)","","                Text {","                    \"This homepage is one of two pages in our site. You can navigate to the About page using the link in the header.\"","                }","                .margins(at: .bottom)","","                Text {","                    \"Learn more about WebUI by exploring this site!\"","                }","                .font(weight: .semibold)","            }","            .frame(maxWidth: .fraction(2, 3))","            .margins(at: .horizontal, auto: true)","        }.render()","    }","}"],"fileName":"Home.swift","identifier":"home-page.swift","fileType":"swift"},"terminal-structure.txt":{"fileName":"Terminal","content":["Sources\/","    WebUI\/","        Components\/","            Layout.swift","        Pages\/","            Home.swift","            About.swift","        Public\/","        Application.swift"],"identifier":"terminal-structure.txt","fileType":"","type":"file","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":5},{"line":6},{"line":7},{"line":8},{"line":9}],"syntax":""},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Build-the-Website":{"kind":"section","role":"pseudoSymbol","title":"Build the Website","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Build-the-Website","type":"section","abstract":[{"type":"text","text":"Learn how to build a simple static website with a home page and an about page using the WebUI library."}],"url":"\/tutorials\/webui\/creating-a-static-site#Build-the-Website"},"terminal-sources.sh":{"fileName":"Terminal","content":["mkdir -p Sources\/Components Sources\/Public","touch Sources\/Pages\/Components\/Layout.swift","touch Sources\/Pages\/Home.swift","touch Sources\/Pages\/About.swift","touch Sources\/Application.swift"],"identifier":"terminal-sources.sh","fileType":"","type":"file","highlights":[],"syntax":""},"about-page.swift":{"content":["import WebUI","","struct About: HTML {","    var document: Document {","        .init(","            path: \"\/about\",","            metadata: Metadata(","                title: \"About\",","                description: \"Learn more about this website and its creator\"","            ),","            content: { self }","        )","    }","","    func render() -> String {","        Layout {","            Section {","                Heading(.title) {","                    \"About This Site\"","                }","                .font(size: .xl3, weight: .bold)","                .margins(at: .bottom, 6)","","                Text {","                    \"This is the About page of my static website built with WebUI. This page demonstrates how to create multiple pages that share common layout elements but have unique content.\"","                }","                .margins(at: .bottom, 4)","","                Heading(.headline) {","                    \"About the Creator\"","                }","                .font(size: .xl, weight: .bold)","                .margins(at: .horizontal, 3)","","                Text {","                    \"I'm a Swift developer who loves building clean, fast websites. This site serves as a demonstration of using Swift for web development.\"","                }","                .margins(at: .bottom, 4)","","                Heading(.headline) {","                    \"Built with WebUI\"","                }","                .font(size: .xl, weight: .bold)","                .margins(at: .vertical)","","                Text {","                    \"WebUI is a Swift library that makes it easy to build static websites using a component-based approach. Key features include:\"","                }","                .margins(of: 4, at: .bottom)","","                List {","                    Item { \"Type-safe HTML generation\" }","                    Item { \"Tailwind-inspired styling API\" }","                    Item { \"Component reusability\" }","                    Item { \"Simple static site generation\" }","                }","                .padding(EdgeInsets(leading: 8))","                .margins(of: 4, at: .bottom)","","                Link(to: \"\/\") {","                    \"Return to Home Page\"","                }","                .margins(of: 4, at: .top)","                .background(color: .blue(._500))","                .font(color: .custom(\"white\"))","                .padding(EdgeInsets(vertical: 2, horizontal: 4))","                .rounded(.md)","            }","            .frame(maxWidth: .fraction(2, 3))","            .margins(at: .horizontal, auto: true)","        }.render()","    }","}"],"fileName":"About.swift","identifier":"about-page.swift","fileType":"swift","type":"file","highlights":[],"syntax":"swift"},"doc://WebUI/tutorials/table-of-contents/Building-Static-Sites":{"kind":"article","abstract":[],"url":"\/tutorials\/table-of-contents\/building-static-sites","title":"Building Static Sites","identifier":"doc:\/\/WebUI\/tutorials\/table-of-contents\/Building-Static-Sites","type":"topic","role":"article"},"terminal-build.sh":{"content":["λ swift run","[1\/1] Planning build","Building for debugging...","[16\/16] Applying Application","Build of product 'Application' complete! (0.98s)","2025-05-14T13:46:47+0100 notice com.webui.setup : [WebUI] Logging system initialized with log level: info","2025-05-14T13:46:47+0100 info com.webui.application : [WebUI] Initialized 'My WebUI Site' with 2 routes, theme: none","2025-05-14T13:46:47+0100 info com.webui.application : [WebUI] Starting build to '\/Users\/user\/Developer\/MyStaticSite\/.output' with assets from 'Sources\/Public'","2025-05-14T13:46:47+0100 info com.webui.application : [WebUI] Building 2 routes","2025-05-14T13:46:47+0100 info com.webui.application : [WebUI] Copying assets from '\/Users\/user\/Developer\/MyStaticSite\/Sources\/Public' to '\/Users\/user\/Developer\/MyStaticSite\/.output\/public'","2025-05-14T13:46:47+0100 info com.webui.application : [WebUI] Build completed successfully with 2 routes"],"fileName":"Terminal","identifier":"terminal-build.sh","fileType":"","type":"file","highlights":[],"syntax":""},"layout-component.swift":{"fileName":"Layout.swift","content":["import Foundation","import WebUI","","struct Layout: HTML {","    let children: Children","","    init(@HTMLBuilder children: @escaping HTMLContentBuilder) {","        self.children = Children(content: children)","    }","","    public func render() -> String {","        Stack {","            Header {","                Link(to: \"\/\") { Application.metadata.site ?? \"\" }.font(size: .xl2)","                Navigation {","                    for path in Application.routes {","                        Link(to: path.path ?? \"\") { path.metadata.title ?? \"\" }","                            .nav()","                            .font(size: .sm)","                    }","                }.flex(align: .center).spacing(of: 2, along: .x)","            }","            .flex(justify: .between, align: .center)","            .frame(width: .screen)","            .margins(at: .bottom)","            .padding(of: 6, at: .all)","","            Main {","                children.render()","            }","            .flex(grow: .one)","            .font(wrapping: .pretty)","","            Footer {","                Text {","                    \"© \\(Date().formattedYear()) \"","                    Link(to: \"\/\") { Application.metadata.site ?? \"\" }.font(","                        weight: .normal","                    )","                }.font(","                    size: .sm,","                    color: .neutral(._700, opacity: 0.7),","                )","            }","            .flex(justify: .center, align: .center)","            .padding(EdgeInsets(all: 4))","        }","        .font(family: Application.theme.fonts[\"body\"] ?? \"system-ui\")","        .frame(minHeight: .screen)","        .flex(direction: .column)","        .render()","    }","}"],"identifier":"layout-component.swift","fileType":"swift","type":"file","highlights":[],"syntax":"swift"},"application-main.swift":{"content":["import Foundation","import WebUI","","@main","actor Application {","    static let metadata = Metadata(","        site: \"My WebUI Site\",","        description: \"A static website built with Swift and WebUI\",","        author: \"Swift Developer\",","        keywords: [","            \"swift\", \"web development\", \"static site\", \"webui\",","        ],","        type: .website","    )","","    static let routes = [","        HomePage().document,","        AboutPage().document,","    ]","","    static func main() async {","        do {","            try Website(","                metadata: metadata,","                theme: theme,","                stylesheets: stylesheets,","                routes: routes,","            ).build()","        } catch {","            print(\"Failed to build application: \\(error)\")","        }","    }","}"],"fileName":"Application.swift","identifier":"application-main.swift","fileType":"swift","type":"file","highlights":[],"syntax":"swift"},"terminal-init.sh":{"fileName":"Terminal","content":["mkdir my-static-site","cd my-static-site","swift package init --type executable"],"identifier":"terminal-init.sh","fileType":"","type":"file","highlights":[],"syntax":""},"final-output.png":{"identifier":"final-output.png","variants":[{"url":"\/images\/WebUI\/final-output.png","traits":["1x","light"]}],"type":"image","alt":"Previewing the site locally"},"doc://WebUI/tutorials/table-of-contents":{"kind":"overview","url":"\/tutorials\/table-of-contents","abstract":[{"text":"WebUI is a Swift library for creating websites with a declarative, component-based approach. Follow these tutorials to learn how to build beautiful static and dynamic websites with Swift.","type":"text"}],"type":"topic","title":"Learning WebUI","role":"overview","identifier":"doc:\/\/WebUI\/tutorials\/table-of-contents"},"doc://WebUI/tutorials/WebUI/creating-a-static-site#Create-the-About-Page":{"kind":"section","abstract":[{"type":"text","text":"Learn how to build a simple static website with a home page and an about page using the WebUI library."}],"url":"\/tutorials\/webui\/creating-a-static-site#Create-the-About-Page","title":"Create the About Page","identifier":"doc:\/\/WebUI\/tutorials\/WebUI\/creating-a-static-site#Create-the-About-Page","type":"section","role":"pseudoSymbol"}}}